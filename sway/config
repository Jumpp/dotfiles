### Variables: mod + direction keys
set $mod Mod4
set $left h
set $down j
set $up k
set $right l

### Variables: applications
set $term foot
set $browser chromium-browser
set $editor code
set $files thunar
set $firefox firefox
set $slack flatpak run com.slack.Slack
set $teams teams-for-linux
set $spotify flatpak run com.spotify.Client
set $outlook chromium-browser --profile-directory=Default --app-id=faolnafnngnfdaknnbpnkhgohbobgegn
set $podman podman-desktop

### Variables: launcher
set $rofi_cmd rofi -terminal $term
set $menu $rofi_cmd -show combi -combi-modes drun#run -modes combi

### Output / idle
output * bg ~/Pictures/backgrounds/bg7.png fill

exec swayidle -w \
    timeout 900 'swaylock -f -c aa0000' \
    timeout 1800 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
    before-sleep 'swaylock -f -c aa0000'

### Startup
exec mako
exec_always kanshi

exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
exec /usr/libexec/xdg-desktop-portal-wlr

exec wl-paste --watch cliphist store

### Window rules
for_window [app_id="term-float"] floating enable, resize set 1000 600, move position center
# for_window [app_id="term-float"] floating enable, move position center
for_window [app_id="qalculate"] floating enable
for_window [app_id="blueman-manager"] floating enable
for_window [window_type="dialog"] floating enable
for_window [window_role="dialog"] floating enable
for_window [app_id="org.kde.xwaylandvideobridge"] floating enable, move scratchpad
for_window [app_id="PanGPUI"] floating enable, sticky enable

### Variables: workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"

assign [class="Chromium-browser"] $ws1
assign [app_id="chromium-browser"] $ws1
assign [class="Code"] $ws1
assign [app_id="code"] $ws1
assign [class="Podman Desktop"] $ws2
assign [app_id="com.slack.Slack"] $ws3
assign [app_id="teams-for-linux"] $ws3
assign [app_id="chrome-faolnafnngnfdaknnbpnkhgohbobgegn-Default"] $ws3
assign [class="Firefox"] $ws4
assign [app_id="firefox"] $ws4
assign [class="Spotify"] $ws5

### General behavior / appearance
floating_modifier $mod normal

gaps inner 8
gaps outer 2
smart_gaps one

default_border pixel 1
default_floating_border pixel 2
titlebar_border_thickness 0
titlebar_padding 0 0
font pango:monospace 0.1

### Input
input * {
    xkb_layout fi
    xkb_variant nodeadkeys
    xkb_options "caps:escape,lv3:ralt_switch"
}

input type:touchpad {
    tap enabled
    tap_button_map lrm
    click_method clickfinger
    dwt enabled
    natural_scroll enabled
}

### Keybindings: app launch
bindsym $mod+c exec $editor
bindsym $mod+e exec foot --app-id=term-float nvim ~/notes.md
bindsym $mod+i exec $firefox
bindsym $mod+o exec $files
bindsym $mod+s exec $slack
bindsym $mod+t exec foot --app-id=term-float

### Keybindings: system / launcher
bindsym $mod+Space exec $menu
bindsym $mod+Shift+q kill
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec ~/dotfiles/scripts/power-menu.sh
bindsym $mod+Shift+p exec grim -g "$(slurp)" - | wl-copy

### Keybindings: focus / move
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

### Keybindings: workspaces
bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9

### Keybindings: layout
bindsym $mod+Shift+s toggle split
bindsym $mod+a focus parent
bindsym $mod+f fullscreen
bindsym $mod+m layout toggle tabbed split
bindsym $mod+n floating toggle

### Keybindings: scratchpad
bindsym $mod+minus move scratchpad
bindsym $mod+plus exec ~/dotfiles/scripts/scratchpad-menu.sh

### Keybindings: resize
bindsym {
    $mod+ctrl+h resize shrink width 5 ppt
    $mod+ctrl+j resize grow height 5 ppt
    $mod+ctrl+k resize shrink height 5 ppt
    $mod+ctrl+l resize grow width 5 ppt
}

### Keybindings: gestures / misc
bindgesture swipe:right workspace next
bindgesture swipe:left workspace prev

bindsym $mod+aring exec swaymsg output eDP-1 enable && ~/.local/bin/screen-flip
bindsym $mod+v exec cliphist list | head -n 200 | rofi -dmenu -i -sorting-method fzf | cliphist decode | wl-copy

### Include layered distro/user config
include '$(/usr/libexec/sway/layered-include "/usr/share/sway/config.d/*.conf" "/etc/sway/config.d/*.conf" "${XDG_CONFIG_HOME:-$HOME/.config}/sway/config.d/*.conf")'
